# .env.example
# ==========================================
# Frontend Secrets (Vite Environment)
# ==========================================
# To hide Firebase configuration from the public JSON file, copy these variables
# into your hosting service's secrets or a local .env file.
VITE_FIREBASE_PROJECT_ID=your_proj_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_auth_domain
VITE_FIRESTORE_DATABASE_ID=your_db_id
VITE_FIREBASE_STORAGE_BUCKET=your_bucket
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

VITE_GEMINI_API_KEY=your_gemini_api_key
VITE_ADMIN_EMAIL=moashrafsy@gmail.com

# ==========================================
# Backend Secrets (Server Environment)
# ==========================================
# Used to derive Vault cryptography keys 
ENCRYPT_KEY=your_very_secure_random_string_here
VAULT_SALT=another_random_salt_string
